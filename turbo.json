{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build:frontend": {
			"outputs": ["dist/ui/**"],
			"inputs": [
				"apps/ui/**",
				"apps/ui/tsconfig.json",
				"apps/ui/package.json",
				"bun.lock"
			]
		},
		"build:backend": {
			"outputs": ["dist/api/**"],
			"inputs": [
				"apps/api/**",
				"apps/api/tsconfig.json",
				"apps/api/package.json",
				"bun.lock"
			]
		},
		"build": {
			"dependsOn": ["build:frontend", "build:backend"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"dependsOn": ["build"],
			"outputs": [],
			"inputs": [
				"apps/**",
				".eslintrc.js",
				"package.json",
				"bun.lock"
			]
		},
		"test": {
			"dependsOn": ["build"],
			"outputs": [],
			"inputs": ["apps/**", "tests/**", "package.json", "bun.lock"]
		},
		"dev": {
			"dependsOn": [],
			"outputs": [],
			"inputs": [
				"apps/**",
				"tsconfig.json",
				"package.json",
				"bun.lock"
			],
			"cache": false,
			"persistent": true
		}
	}
}
