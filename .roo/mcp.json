{
	"mcpServers": {
		"brave-search": {
			"type": "stdio",
			"command": "bash",
			"args": [
				"./bun.sh",
				"run",
				"./apps/langgraph-control-plane/src/mcpSearchServer.ts"
			],
			"env": {
				"SEARCH_PROVIDER": "searxng",
				"SEARXNG_BASE_URL": "http://10.87.212.49:8080"
			},
			"alwaysAllow": [
				"searxng_web_search",
				"brave_web_search",
				"brave_local_search"
			]
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp",
				"--headless",
				"--caps",
				"vision,devtools",
				"--isolated"
			],
			"alwaysAllow": [
				"browser_navigate",
				"browser_install",
				"browser_take_screenshot",
				"browser_resize",
				"browser_network_requests",
				"browser_run_code",
				"browser_snapshot",
				"browser_console_messages",
				"browser_wait_for"
			]
		},
		"browser-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"browser-devtools-mcp"
			],
			"disabledTools": [
				"stub_intercept-http-request",
				"stub_mock-http-response"
			],
			"alwaysAllow": [],
			"disabled": true
		}
	}
}
