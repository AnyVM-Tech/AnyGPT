# AnyGPT API (OpenAI-compatible) base URL
# Default for local (non-docker) LibreChat.
# If LibreChat runs in Docker, use host.docker.internal to reach the host.
ANYGPT_BASE_URL=http://localhost:3000/v1

# AnyGPT API key (Bearer token)
ANYGPT_API_KEY=replace_with_anygpt_api_key

# Keycloak / OpenID Connect (LibreChat OpenID envs)
OPENID_CLIENT_ID=AnyGPT
OPENID_CLIENT_SECRET=replace_with_keycloak_client_secret
OPENID_ISSUER=https://auth.anyvm.tech/realms/anyvm
OPENID_SCOPE="openid profile email"
OPENID_CALLBACK_URL=/oauth/openid/callback
OPENID_SESSION_SECRET=replace_with_random_session_secret
OPENID_BUTTON_LABEL=Continue with AnyVM SSO
OPENID_IMAGE_URL=/assets/AnyVM-logo.png
OPENID_AUTO_REDIRECT=false
OPENID_USE_PKCE=true
OPENID_REUSE_TOKENS=true
# OPENID_REQUIRED_ROLE=  # uncomment and set to enforce a Keycloak role
# OPENID_ADMIN_ROLE=     # uncomment and set to map a Keycloak role to LibreChat admin
OPENID_USE_END_SESSION_ENDPOINT=true
OPENID_POST_LOGOUT_REDIRECT_URI=https://gpt.anyvm.tech
DOMAIN_CLIENT=https://gpt.anyvm.tech
DOMAIN_SERVER=https://gpt.anyvm.tech

# Branding / theme defaults (AnyGPT product, AnyVM platform)
APP_TITLE=AnyGPT
CUSTOM_FOOTER="Powered by AnyVM"
# Set to / to hide LibreChat's stock help link in the account menu.
HELP_AND_FAQ_URL=/
REACT_APP_THEME_TEXT_PRIMARY=#62bfe7
REACT_APP_THEME_TEXT_SECONDARY=#47b9e7
REACT_APP_THEME_TEXT_TERTIARY=#2d9de0
