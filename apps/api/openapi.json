    "/v1/videos": {
      "get": {
        "summary": "List videos",
        "description": "Lists recently generated video jobs.",
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "after",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Video list"
          }
        }
      },
      "post": {
        "summary": "Create video",
        "description": "Creates a video generation job. Use POST on this path; GET /v1/videos lists jobs. For Veo models, use `aspect_ratio` (or `aspectRatio`) with `16:9` or `9:16`, and `duration` / `seconds` with `4`, `6`, or `8`. On the current Gemini-backed Veo 3 and Veo 3.1 path, audio is native to the model and `generate_audio` / `generateAudio` are compatibility fields only; they do not disable audio output.",
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video generation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationAcceptedResponse"
                }
              }
            }
          }
        }
      }
    },
