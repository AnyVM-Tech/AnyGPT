ExecStartPre=/bin/sh -lc 'target="${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET:-${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://[redacted-ip]:3310}/openapi.json}"; timeout="${ANYGPT_EXPERIMENTAL_STARTUP_HEALTHCHECK_TIMEOUT_SEC:-5}"; thread_id="${ANYGPT_CONTROL_PLANE_THREAD_ID:-${ANYGPT_EXPERIMENTAL_VALIDATION_THREAD:-8bd76091-7a92-4314-abf8-926521f7bacf:api-platform}}"; api_base_url="${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://[redacted-ip]:3310}"; api_port=$(printf "%s" "$api_base_url" | sed -n "s#.*:\([0-9][0-9]*\)/*$#\1#p"); if [ -n "$api_port" ] && command -v ss >/dev/null 2>&1; then port_owner_pid=$(ss -ltnp 2>/dev/null | awk -v port=":${api_port}" 'index($0, port) { if (match($0, /pid=([0-9]+)/, m)) { print m[1]; exit } }'); if [ -n "$port_owner_pid" ]; then echo "[experimental-preflight] startup port owner detected: port=$api_port pid=$port_owner_pid thread=$thread_id partial_readiness_only_until_fresh_same_thread_langsmith_run_and_smoke_typecheck"; else echo "[experimental-preflight] startup port owner missing: port=$api_port thread=$thread_id partial_readiness_only_until_fresh_same_thread_langsmith_run_and_smoke_typecheck"; fi; fi; if command -v curl >/dev/null 2>&1; then code=$(curl -fsS -I -o /dev/null -w "%{http_code}" --max-time "$timeout" "$target" 2>/dev/null || true); if [ -z "$code" ] || [ "$code" = "000" ] || [ "$code" = "405" ] || [ "$code" = "501" ]; then code=$(curl -fsS -o /dev/null -w "%{http_code}" --max-time "$timeout" "$target") || { echo "[experimental-preflight] startup validation target unreachable: $target" >&2; echo "[experimental-preflight] operator_defer_reason=preflight_unreachable_for_${thread_id}_preserve_no_run_defer_reason_until_fresh_same_thread_langsmith_run_and_smoke_typecheck"; exit 1; }; probe_method=get; else probe_method=head; fi; export ANYGPT_EXPERIMENTAL_STARTUP_PROBE_METHOD="${probe_method:-unknown}"; export ANYGPT_EXPERIMENTAL_STARTUP_PROBE_HTTP_STATUS="$code"; defer_reason="${ANYGPT_EXPERIMENTAL_STARTUP_DEFER_REASON:-preserve_no_run_defer_reason_until_fresh_same_thread_run_and_smoke}"; pending_runs="${ANYGPT_CONTROL_PLANE_PENDING_RUNS:-${ANYGPT_EXPERIMENTAL_PENDING_RUN_COUNT:-unknown}}"; printf "ANYGPT_EXPERIMENTAL_STARTUP_PROBE_METHOD=%s\nANYGPT_EXPERIMENTAL_STARTUP_PROBE_HTTP_STATUS=%s\nANYGPT_EXPERIMENTAL_STARTUP_LOCAL_VALIDATION_TARGET=%s\nANYGPT_EXPERIMENTAL_STARTUP_LOCAL_PROBE_METHOD=%s\nANYGPT_EXPERIMENTAL_STARTUP_HEALTHCHECK_TIMEOUT_SEC=%s\nANYGPT_EXPERIMENTAL_STARTUP_DEFER_REASON=%s\nANYGPT_EXPERIMENTAL_PENDING_RUN_COUNT=%s\n" "${probe_method:-unknown}" "$code" "${ANYGPT_EXPERIMENTAL_STARTUP_LOCAL_VALIDATION_TARGET:-http://[redacted-ip]:${PORT:-3310}/openapi.json}" "get" "$timeout" "$defer_reason" "$pending_runs" > "${ANYGPT_EXPERIMENTAL_STARTUP_PROBE_ENV_PATH:-%t/anygpt/experimental-preflight.env}" 2>/dev/null || true; echo "[experimental-preflight] startup validation target responded: target=$target http=$code method=${probe_method:-get} thread=$thread_id pending_runs=$pending_runs defer_reason=$defer_reason partial_readiness_only_until_fresh_same_thread_langsmith_run_and_smoke_typecheck"; case "$code" in 2*|3*) exit 0 ;; *) echo "[experimental-preflight] startup validation target unhealthy: $target http=$code method=${probe_method:-get}" >&2; echo "[experimental-preflight] operator_defer_reason=preflight_http_${code}_for_${thread_id}_preserve_no_run_defer_reason_until_fresh_same_thread_langsmith_run_and_smoke_typecheck"; exit 1 ;; esac; else echo "[experimental-preflight] curl unavailable; skipping HTTP preflight for $target" >&2; export ANYGPT_EXPERIMENTAL_STARTUP_PROBE_METHOD=unavailable; export ANYGPT_EXPERIMENTAL_STARTUP_PROBE_HTTP_STATUS=unavailable; defer_reason="${ANYGPT_EXPERIMENTAL_STARTUP_DEFER_REASON:-preserve_no_run_defer_reason_until_fresh_same_thread_run_and_smoke}"; pending_runs="${ANYGPT_CONTROL_PLANE_PENDING_RUNS:-${ANYGPT_EXPERIMENTAL_PENDING_RUN_COUNT:-unknown}}"; printf "ANYGPT_EXPERIMENTAL_STARTUP_PROBE_METHOD=%s\nANYGPT_EXPERIMENTAL_STARTUP_PROBE_HTTP_STATUS=%s\nANYGPT_EXPERIMENTAL_STARTUP_DEFER_REASON=%s\nANYGPT_EXPERIMENTAL_PENDING_RUN_COUNT=%s\n" "unavailable" "unavailable" "$defer_reason" "$pending_runs" > "${ANYGPT_EXPERIMENTAL_STARTUP_PROBE_ENV_PATH:-%t/anygpt/experimental-preflight.env}" 2>/dev/null || true; echo "[experimental-preflight] operator_defer_reason=curl_unavailable_for_${thread_id}_preserve_no_run_defer_reason_until_fresh_same_thread_langsmith_run_and_smoke_typecheck pending_runs=$pending_runs defer_reason=$defer_reason"; fi'
