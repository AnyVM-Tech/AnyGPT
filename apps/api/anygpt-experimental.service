[Unit]
Description=AnyGPT API Service (Experimental)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5
StartLimitAction=none
OnFailure=anygpt-experimental-status@%n.service
OnSuccess=anygpt-experimental-status@%n.service

[Service]
Type=notify
NotifyAccess=all
WatchdogSec=60
WatchdogSignal=SIGTERM
TimeoutStartSec=120
ExecStartPost=/bin/sh -lc 'target="${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET:-${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://[redacted-ip]:3310}/openapi.json}"; localhost_target="${ANYGPT_EXPERIMENTAL_STARTUP_LOCAL_VALIDATION_TARGET:-http://127.0.0.1:${PORT:-3310}/openapi.json}"; timeout="${ANYGPT_EXPERIMENTAL_STARTUP_HEALTHCHECK_TIMEOUT_SEC:-5}"; thread_id="${ANYGPT_CONTROL_PLANE_THREAD_ID:-${ANYGPT_EXPERIMENTAL_VALIDATION_THREAD:-b31cedc0-ceb5-48d7-8772-cf97f38a3b42:api-platform}}"; if command -v curl >/dev/null 2>&1; then code=$(curl -fsS -o /dev/null -w "%{http_code}" --max-time "$timeout" "$target" 2>/dev/null || true); localhost_code=$(curl -fsS -o /dev/null -w "%{http_code}" --max-time "$timeout" "$localhost_target" 2>/dev/null || true); if [ -n "$code" ] && [ "$code" != "000" ]; then /usr/bin/systemd-notify --status="experimental-api poststart_target=$target poststart_http=$code localhost_target=$localhost_target localhost_http=${localhost_code:-unreachable} thread=$thread_id partial_readiness_only_until_fresh_same_thread_langsmith_run_and_smoke_typecheck" || true; elif [ -n "$localhost_code" ] && [ "$localhost_code" != "000" ]; then /usr/bin/systemd-notify --status="experimental-api poststart_target=$target poststart_http=unreachable localhost_target=$localhost_target localhost_http=$localhost_code thread=$thread_id partial_readiness_only_until_fresh_same_thread_langsmith_run_and_smoke_typecheck" || true; else /usr/bin/systemd-notify --status="experimental-api poststart_target=$target poststart_http=unreachable localhost_target=$localhost_target localhost_http=unreachable thread=$thread_id partial_readiness_only_until_fresh_same_thread_langsmith_run_and_smoke_typecheck" || true; fi; else /usr/bin/systemd-notify --status="experimental-api poststart_target=$target poststart_http=curl_unavailable localhost_target=$localhost_target localhost_http=curl_unavailable thread=$thread_id partial_readiness_only_until_fresh_same_thread_langsmith_run_and_smoke_typecheck" || true; fi'
TimeoutStopSec=30
TimeoutStartFailureMode=terminate
TimeoutAbortSec=45
RestartKillSignal=SIGTERM
WorkingDirectory=%h/AnyGPT/apps/api
EnvironmentFile=-%t/anygpt/experimental-preflight.env
ExecStartPre=/usr/bin/install -d -m 0750 %t/anygpt
ExecStartPre=/bin/sh -lc 'snapshot_path="${ANYGPT_EXPERIMENTAL_STARTUP_PRECHECK_SNAPSHOT_PATH:-%t/anygpt/anygpt-experimental-startup-precheck.env}"; snapshot_dir="$(dirname "$snapshot_path")"; /usr/bin/install -d -m 0750 "$snapshot_dir"; target="${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET:-${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://127.0.0.1:3310}/openapi.json}"; timeout_sec="${ANYGPT_EXPERIMENTAL_STARTUP_HEALTHCHECK_TIMEOUT_SEC:-5}"; started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; curl_output="$(curl -fsS -o /dev/null -w "http_status=%{http_code} time_total=%{time_total}" --max-time "$timeout_sec" "$target" 2>&1)"; curl_status=$?; http_status="unknown"; latency_ms="unknown"; case "$curl_output" in *http_status=*) http_status="$(printf "%s" "$curl_output" | sed -n "s/.*http_status=\([0-9][0-9][0-9]\).*/\1/p" | tail -n 1)" ;; esac; case "$curl_output" in *time_total=*) latency_ms="$(printf "%s" "$curl_output" | sed -n "s/.*time_total=\([0-9.][0-9.]*\).*/\1/p" | tail -n 1 | awk '{ printf "%d", ($1 * 1000) }')" ;; esac; if [ "$curl_status" -eq 0 ]; then precheck_result="reachable"; else precheck_result="unreachable"; fi; curl_output_sanitized="$(printf "%s" "$curl_output" | tr "\n" " " | tr -s " " | sed "s/[^[:print:]]/?/g")"; { printf "%s\n" "startup_precheck_started_at=$started_at" "startup_precheck_target=$target" "startup_precheck_result=$precheck_result" "startup_precheck_curl_exit_code=$curl_status" "startup_precheck_http_status=${http_status:-unknown}" "startup_precheck_latency_ms=${latency_ms:-unknown}" "startup_precheck_curl_available=$(if command -v curl >/dev/null 2>&1; then printf yes; else printf no; fi)" "startup_precheck_curl_status=$curl_status" "startup_precheck_curl_output=${curl_output_sanitized:-unknown}" "startup_precheck_thread=${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_THREAD:-unknown}" "startup_precheck_scope=${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_SCOPE:-unknown}" "startup_precheck_goal=${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_GOAL:-unknown}" "startup_precheck_repair_signal=${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_REPAIR_SIGNAL:-langsmith_feedback_contains_goal_context_0_and_repair_smoke_passed_0}" "startup_precheck_validation_expectation=${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_EXPECTATION:-fresh_same_thread_langsmith_run_with_goal_context_and_passed_smoke_typecheck_or_clear_no_run_defer_reason}" "startup_precheck_browser_checked_at=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_AT:-unknown}" "startup_precheck_browser_target=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_TARGET:-${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET:-${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://[redacted-ip]:3310}/openapi.json}}" "startup_precheck_browser_http_status=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_HTTP_STATUS:-unknown}" "startup_precheck_browser_latency_ms=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_LATENCY_MS:-unknown}" "startup_precheck_browser_request_count=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_REQUEST_COUNT:-unknown}" "startup_precheck_probe_method=${ANYGPT_EXPERIMENTAL_STARTUP_PROBE_METHOD:-unknown}" "startup_precheck_browser_observed_url=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_URL:-${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_TARGET:-${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET:-${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://[redacted-ip]:3310}/openapi.json}}}" "startup_precheck_browser_target_alignment=$(browser_target="${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_TARGET:-${ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET:-${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://[redacted-ip]:3310}/openapi.json}}"; browser_url="${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_URL:-$browser_target}"; if [ "$browser_target" = "$browser_url" ]; then printf matched; else printf mismatched; fi)" "startup_precheck_browser_target_alignment=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_TARGET_ALIGNMENT:-unknown}" "startup_precheck_browser_summary=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_SUMMARY:-unknown}" "startup_precheck_pending_runs=${ANYGPT_EXPERIMENTAL_PENDING_RUNS:-unknown}" "startup_precheck_browser_note=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_NOTE:-playwright_openapi_navigation_and_network_capture_are_partial_observability_only_not_a_completed_same_thread_validation_run}"; if [ "$curl_status" -ne 0 ]; then printf "%s\n" "startup_precheck_defer_reason=experimental_api_target_not_reachable_before_service_start_browser_precheck_http_${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK_HTTP_STATUS:-unknown}_preserve_operator_no_run_defer_reason_until_fresh_same_thread_run_and_smoke"; else printf "%s\n" "startup_precheck_defer_reason=browser_openapi_precheck_and_startup_probe_are_partial_readiness_only_preserve_operator_no_run_defer_reason_until_fresh_same_thread_run_and_smoke"; fi; } > "$snapshot_path"'
Restart=on-failure
RestartSec=10
RestartSteps=3
RestartMaxDelaySec=60
Environment=ANYGPT_EXPERIMENTAL_API_BASE_URL=http://[redacted-ip]:3310
Environment=ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET=${ANYGPT_EXPERIMENTAL_API_BASE_URL}/openapi.json
