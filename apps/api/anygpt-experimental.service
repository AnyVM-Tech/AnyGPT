HECK_INTERVAL_SEC:-15} health_timeout_sec=${ANYGPT_EXPERIMENTAL_STARTUP_HEALTHCHECK_TIMEOUT_SEC:-5} thread=${ANYGPT_CONTROL_PLANE_THREAD_ID:-${ANYGPT_EXPERIMENTAL_VALIDATION_THREAD:-8bd76091-7a92-4314-abf8-926521f7bacf:api-platform}} pending_runs=${ANYGPT_CONTROL_PLANE_PENDING_RUNS:-${ANYGPT_EXPERIMENTAL_PENDING_RUN_COUNT:-unknown}} defer=${ANYGPT_EXPERIMENTAL_STARTUP_DEFER_REASON:-preserve_no_run_defer_reason_until_fresh_same_thread_run_and_smoke} validation=${ANYGPT_EXPERIMENTAL_BROWSER_OPENAPI_PRECHECK:+partial_until_fresh_same_thread_run_and_smoke}
