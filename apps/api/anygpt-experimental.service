[Unit]
Description=AnyGPT API Service (Experimental)
After=network.target
StartLimitIntervalSec=300
StartLimitBurst=5
StartLimitAction=none
OnFailure=anygpt-experimental-status@%n.service
OnSuccess=anygpt-experimental-status@%n.service

[Service]
Type=notify
NotifyAccess=all
WatchdogSec=60
TimeoutStartSec=120
TimeoutStopSec=30
TimeoutStartFailureMode=terminate
WorkingDirectory=%h/AnyGPT/apps/api
ExecCondition=/bin/sh -lc 'mkdir -p .control-plane/experimental; : > .control-plane/experimental/openapi-startup-snapshot.status; if [ ! -f %h/AnyGPT/apps/api/server.launcher.bun.ts ]; then printf "%s\n" "startup_result=deferred:missing_launcher" "operator_defer_reason=experimental_service_launcher_missing_at_%h/AnyGPT/apps/api/server.launcher.bun.ts_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_this_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; exit 1; fi; if command -v ss >/dev/null 2>&1; then port_owner_pid=$(ss -ltnp 2>/dev/null | awk '/:3310\b/ { if (match($0, /pid=([0-9]+)/, m)) { print m[1]; exit } }'); if [ -n "$port_owner_pid" ]; then if [ -n "$MAINPID" ] && [ "$port_owner_pid" = "$MAINPID" ]; then printf "%s\n" "prestart_port_3310_owner=self:$port_owner_pid" >> .control-plane/experimental/openapi-startup-snapshot.status; else printf "%s\n" "startup_result=deferred:port_3310_in_use_before_start" "prestart_port_3310_owner=foreign:$port_owner_pid" >> .control-plane/experimental/openapi-startup-snapshot.status; if command -v curl >/dev/null 2>&1 && curl --silent --show-error --fail --max-time 5 http://127.0.0.1:3310/openapi.json >/dev/null 2>&1; then printf "%s\n" "prestart_port_3310_probe=occupied" "prestart_openapi_probe=passed" "prestart_openapi_url=${ANYGPT_EXPERIMENTAL_API_BASE_URL:-http://[redacted-ip]:3310}/openapi.json" "startup_result=deferred:prestart_openapi_already_serving" "operator_defer_reason=experimental_service_port_3310_already_serving_openapi_via_pid_${port_owner_pid}_confirm_runtime_ownership_before_restart_and_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_this_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; else printf "%s\n" "prestart_openapi_probe=failed_or_unavailable" "operator_defer_reason=experimental_service_port_3310_already_in_use_by_pid_${port_owner_pid}_confirm_runtime_ownership_before_restart_and_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_this_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; exit 1; fi; fi; else printf "%s\n" "prestart_port_3310_owner=deferred:ss_unavailable" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; exit 0'
Environment=NODE_ENV=experimental
Environment=API_DIST_DIR=dist/experimental
Environment=PORT=3310
Environment=CLUSTER_WORKERS=1
Environment=PORT_RETRY_COUNT=0
Environment=REDIS_DB_EXPERIMENTAL=1
Environment=EXPERIMENTAL_SOURCE_REDIS_DB=0
Environment=API_EXPERIMENTAL_DATA_DIR=.control-plane/experimental
Environment=ANYGPT_EXPERIMENTAL_OPENAPI_URL=http://[redacted-ip]:3310/openapi.json
Environment=ANYGPT_EXPERIMENTAL_STARTUP_VALIDATION_TARGET=http://[redacted-ip]:3310/openapi.json
Environment=ANYGPT_EXPERIMENTAL_DEFER_REASON=Upstream/provider-bound Gemini capability mismatch and regional catalog drift: repeated provider_cap_blocked/provider_model_removed image_output failures for lyria-3-pro-preview plus generateContent probe failures such as unsupported audio/s16le input and function calling not enabled indicate the blocked subsystem is apps/api Gemini provider routing/capability handling; repeating the same Gemini provider-method combination is unlikely to help immediately, this is not by itself a deploy or rollback trigger, and this experimental iteration should remain deferred until Gemini routing/capability handling or upstream regional availability changes, while the next validation step confirms at least one fresh LangSmith control-plane run or trace for this iteration or preserves this clear no-run defer reason if no run was emitted.
Environment=ANYGPT_EXPERIMENTAL_VALIDATION_SUCCESS=Confirm at least one fresh LangSmith control-plane run or trace for this experimental iteration, or preserve the explicit no-run defer reason when the upstream/provider-bound Gemini capability mismatch in apps/api Gemini provider routing/capability handling prevents a new run from being emitted.
Environment=ANYGPT_EXPERIMENTAL_PROBE_EVIDENCE=image_output: lyria-3-pro-preview -> image generation unavailable in country (gemini-t1-035 provider_cap_blocked) | image_output: lyria- …[truncated 8000 chars]… stream_provider_bound_gemini_capability_mismatch_and_regional_catalog_drift" "gemini_capability_validation_note=retrying_the_same_gemini_provider_method_combination_is_unlikely_to_help_immediately_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_the_clear_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; fi'
ExecStartPost=/bin/sh -lc 'mkdir -p .control-plane/experimental; if [ -n "$MAINPID" ]; then printf "%s\n" "launcher_pid=$MAINPID" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; if command -v systemctl >/dev/null 2>&1; then active_state=$(systemctl show --property=ActiveState --value anygpt-experimental.service 2>/dev/null || true); sub_state=$(systemctl show --property=SubState --value anygpt-experimental.service 2>/dev/null || true); if [ -n "$active_state" ]; then printf "%s\n" "systemd_active_state=$active_state" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; if [ -n "$sub_state" ]; then printf "%s\n" "systemd_sub_state=$sub_state" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; else printf "%s\n" "systemd_state_check=deferred:systemctl_unavailable" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; if command -v ss >/dev/null 2>&1; then if ss -ltn 2>/dev/null | grep -q ":3310\b"; then printf "%s\n" "local_port_listen_check=passed" >> .control-plane/experimental/openapi-startup-snapshot.status; else printf "%s\n" "local_port_listen_check=failed" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; else printf "%s\n" "local_port_listen_check=deferred:ss_unavailable" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; if command -v curl >/dev/null 2>&1; then openapi_body=$(curl --silent --show-error --fail --max-time 10 http://[redacted-ip]:3310/openapi.json 2>/dev/null || true); if [ -n "$openapi_body" ]; then printf "%s\n" "local_openapi_probe=passed" >> .control-plane/experimental/openapi-startup-snapshot.status; if printf "%s" "$openapi_body" | grep -q '"openapi"'; then printf "%s\n" "local_openapi_payload_check=passed" >> .control-plane/experimental/openapi-startup-snapshot.status; else printf "%s\n" "local_openapi_payload_check=failed" "operator_defer_reason=experimental_openapi_payload_missing_openapi_field_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_this_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; else printf "%s\n" "local_openapi_probe=failed" "operator_defer_reason=experimental_openapi_probe_failed_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_this_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; fi; else printf "%s\n" "local_openapi_probe=deferred:curl_unavailable" "operator_defer_reason=experimental_openapi_probe_deferred_because_curl_is_unavailable_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_this_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; fi'
TimeoutStartFailureMode=abort
ExecStopPost=/bin/sh -lc 'mkdir -p .control-plane/experimental; printf "%s\n" "last_stop_timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> .control-plane/experimental/openapi-startup-snapshot.status; if [ "$SERVICE_RESULT" = "timeout" ]; then printf "%s\n" "startup_timeout_observed=1" "operator_defer_reason=experimental_service_startup_timed_out_confirm_a_fresh_langsmith_control_plane_run_trace_or_preserve_this_no_run_defer_reason" >> .control-plane/experimental/openapi-startup-snapshot.status; fi'
Restart=alwaysRestartPreventExitStatus=75
RestartSec=5
User=skullcmd

